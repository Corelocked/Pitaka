# Webhook server
WEBHOOK_PORT=8787
ALLOW_INSECURE_WEBHOOKS=true

# Storage mode: firestore or log
WEBHOOK_SINK_MODE=log

# Firebase Admin credentials (required when WEBHOOK_SINK_MODE=firestore)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# Maya
MAYA_WEBHOOK_SECRET=

# GCash
GCASH_WEBHOOK_SECRET=
