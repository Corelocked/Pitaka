<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/quickActionsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/pitaka_widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quick Actions"
        android:textColor="@color/widget_text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Jump straight into your most-used forms"
        android:textColor="@color/widget_text_secondary"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/quickIncome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/pitaka_widget_row_background"
                android:text="Record Income"
                android:textAllCaps="false"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/quickExpense"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/pitaka_widget_row_background"
                android:text="Log Expense"
                android:textAllCaps="false"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/quickTransfer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/pitaka_widget_row_background"
                android:text="Transfer Funds"
                android:textAllCaps="false"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/quickGoal"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/pitaka_widget_row_background"
                android:text="New Goal"
                android:textAllCaps="false"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/quickSubscription"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:background="@drawable/pitaka_widget_promo_background"
            android:text="New Subscription"
            android:textAllCaps="false"
            android:textColor="@color/widget_promo_text"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
