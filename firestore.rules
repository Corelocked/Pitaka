rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /incomes/{incomeId} {
      // Allow reads only to the owner
      allow get, list: if request.auth != null && resource.data.userId == request.auth.uid;
      // Allow create when the incoming document's userId matches the authenticated user
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      // Allow update/delete only if existing resource belongs to the user
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /expenses/{expenseId} {
      allow get, list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /savings/{savingsId} {
      allow get, list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /categories/{categoryId} {
      allow get, list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Wallets collection — owner-only access (mirrors other collections)
    match /wallets/{walletId} {
      allow get, list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Lendings collection — track money lent/borrowed per user
    match /lendings/{lendingId} {
      allow get, list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Transfers collection — track wallet-to-wallet moves per user
    match /transfers/{transferId} {
      allow get, list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Investments collection — track holdings per user
    match /investments/{investmentId} {
      allow get, list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // User profiles — each signed-in user can read and manage only their own profile document
    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.plan in ['basic', 'pro']
        && request.resource.data.tags is list;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.plan in ['basic', 'pro']
        && request.resource.data.tags is list;
      allow delete: if false;
    }
  }
}
