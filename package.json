{
  "name": "budget-book",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:android": "npm run build && npx cap sync android",
    "apk:debug": "npm run build:android && cd android && gradlew.bat assembleDebug",
    "apk:release": "npm run build:android && cd android && gradlew.bat assembleRelease",
    "cap:sync": "npx cap sync",
    "android:open": "npx cap open android",
    "lint": "eslint .",
    "preview": "vite preview",
    "payments:dev": "node --env-file=server/payments/.env server/payments/index.js",
    "webhooks:dev": "node server/webhooks/index.js",
    "webhooks:test": "node server/webhooks/test-normalizers.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "express": "^5.1.0",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "npm:rolldown-vite@7.2.5"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  }
}
